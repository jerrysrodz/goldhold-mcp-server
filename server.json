{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.jerrysrodz/goldhold",
  "description": "Persistent memory for AI agents. Search, store, and recall across sessions.",
  "repository": {
    "url": "https://github.com/jerrysrodz/goldhold-mcp-server",
    "source": "github"
  },
  "version": "1.2.0",
  "websiteUrl": "https://goldhold.ai",
  "icons": [
    {
      "src": "https://goldhold.ai/logo-icon.png",
      "mimeType": "image/png"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@goldhold/mcp-server",
      "version": "1.2.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "GoldHold API key from goldhold.ai/account",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "GOLDHOLD_API_KEY"
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.goldhold.ai/mcp"
    },
    {
      "type": "streamable-http",
      "url": "https://relay.goldhold.ai/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer token: your GoldHold API key from goldhold.ai/account",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
